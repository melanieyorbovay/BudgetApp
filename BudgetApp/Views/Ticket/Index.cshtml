@model List<BudgetApp.ModelsV2.Ticket>
@{
    ViewData["Title"] = "Tickets";
}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-receipt me-2"></i>Gestion des tickets</h2>
        <a href="/Ticket/Ajouter" class="btn btn-success">
            <i class="fas fa-plus me-1"></i> Nouveau ticket
        </a>
    </div>
    <!--filtres-->
    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Mois</label>
                    <select name="mois" class="form-select">
                        <option value="0" selected="@(ViewBag.Mois == 0)">Tous</option>
                        <option value="1" selected="@(ViewBag.Mois == 1)">Janvier</option>
                        <option value="2" selected="@(ViewBag.Mois == 2)">Février</option>
                        <option value="3" selected="@(ViewBag.Mois == 3)">Mars</option>
                        <option value="4" selected="@(ViewBag.Mois == 4)">Avril</option>
                        <option value="5" selected="@(ViewBag.Mois == 5)">Mai</option>
                        <option value="6" selected="@(ViewBag.Mois == 6)">Juin</option>
                        <option value="7" selected="@(ViewBag.Mois == 7)">Juillet</option>
                        <option value="8" selected="@(ViewBag.Mois == 8)">Août</option>
                        <option value="9" selected="@(ViewBag.Mois == 9)">Septembre</option>
                        <option value="10" selected="@(ViewBag.Mois == 10)">Octobre</option>
                        <option value="11" selected="@(ViewBag.Mois == 11)">Novembre</option>
                        <option value="12" selected="@(ViewBag.Mois == 12)">Décembre</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Année</label>
                    <select name="annee" class="form-select">
                        <option value="0" selected="@(ViewBag.Annee == 0)">Toutes</option>
                        <option value="2025" selected="@(ViewBag.Annee == 2025)">2025</option>
                        <option value="2026" selected="@(ViewBag.Annee == 2026)">2026</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter me-1"></i> Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>
    <!-- Liste Achats -->
    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="thead-violet">
                    <tr>
                        <th>Date</th>
                        <th>Magasin</th>
                        <th>Localité</th>
                        <th class="text-end">Total CHF</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model)
                    {
                        <tr>
                            <td>@ticket.DateAchat.ToString("dd.MM.yyyy")</td>
                            <td>@ticket.Magasin?.NomMagasin</td>
                            <td>@ticket.Magasin?.Localite</td>
                            <td class="text-end">@ticket.Total.ToString("N2")</td>
                            <td class="text-center">
                                <a href="/Ticket/Detail/@ticket.IdTicket"
                                   class="btn btn-sm btn-info text-white me-1">
                                    <i class="fas fa-eye"></i> Détail
                                </a>
                                <a href="/Ticket/AjouterLignes/@ticket.IdTicket"
                                   class="btn btn-sm btn-warning me-1">
                                   <i class="fas fa-edit"></i> Modifier
                               </a>
                                <a href="/Ticket/Imprimer/@ticket.IdTicket"
                                   class="btn btn-sm btn-secondary me-1">
                                    <i class="fas fa-print"></i> Imprimer
                                </a>
                                <form method="post" action="/Ticket/SupprimerTicket" class="d-inline">
                                    <input type="hidden" name="idTicket" value="@ticket.IdTicket" />
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Supprimer ce ticket et toutes ses lignes ?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
