@model BudgetApp.ModelsV2.Article
@{
    ViewData["Title"] = "Modifier l'article";
    var categories = ViewBag.Categories as List<BudgetApp.ModelsV2.Categorie>;
}
<div class="container py-4" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-edit me-2" style="color:#6C3FC5"></i>Modifier l'article</h2>
        <a href="/Article" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Retour    
        </a>
    </div>

    @if (ViewBag.Erreur != null)
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle me-2"></i>@ViewBag.Erreur
        </div>
    }

    <div class="card-theme card">
        <div class="card-header card-header-violet">
            <i class="fas fa-box me-2"></i>@Model.NomArticle
        </div>
        <div class="card-body">
            <form method="post" action="/Article/Modifier">
                <input type="hidden" name="idArticle" value="@Model.IdArticle" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Nom de l'article</label>
                    <input type="text" name="nomArticle" class="form-control" value="@Model.NomArticle" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Unité</label>
                    <select name="unite" class="form-select" required>
                        <option value="pce" selected="@(Model.Unite == "pce")">Pièce</option>
                        <option value="kg" selected="@(Model.Unite == "kg")">kg</option>
                        <option value="L" selected="@(Model.Unite == "L")">L</option>
                        <option value="g" selected="@(Model.Unite == "g")">g</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Catégorie</label>
                    <select name="idCategorie" class="form-select" required>
                        @foreach (var cat in categories)
                            {
                                <option value="@cat.IdCategorie"
                                        selected="@(Model.IdCategorie == cat.IdCategorie)">
                                    @cat.NomCategorie
                                </option>
                            }
                        </select>
                </div>
                <button type="submit" class="btn btn-theme w-100">
                    <i class="fas fa-save me-1"></i> Enregistrer
                </button>
            </form>
        </div>
    </div>

</div>
