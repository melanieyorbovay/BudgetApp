@model BudgetApp.ModelsV2.Article
@{
    ViewData["Title"] = "Historique des prix";
    var lignes = ViewBag.Lignes as List<BudgetApp.ModelsV2.LigneAchat>;
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-chart-line me-2"></i>@Model.NomArticle</h2>
        <a href="/Article" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Retour
        </a>
    </div>

    <!-- Infos article -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <strong><i class="fas fa-box me-1"></i> Article :</strong> @Model.NomArticle
                </div>
                <div class="col-md-4">
                    <strong><i class="fas fa-tag me-1"></i> Catégorie :</strong> @Model.Categorie?.NomCategorie
                </div>
                <div class="col-md-4">
                    <strong><i class="fas fa-ruler me-1"></i> Unité :</strong> @Model.Unite
                </div>
            </div>
        </div>
    </div>

    <!-- Statistiques -->
    @if (lignes != null && lignes.Count > 0)
    {
        <div class="row mb-4 g-3">
            <div class="col-md-3">
                <div class="card shadow text-center">
                    <div class="card-body">
                        <div class="fs-4 fw-bold text-primary">@lignes.Count</div>
                        <div class="text-muted">Achats enregistrés</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow text-center">
                    <div class="card-body">
                        <div class="fs-4 fw-bold text-success">@lignes.Min(l => l.PrixUnitaire).ToString("N2") CHF</div>
                        <div class="text-muted">Prix minimum</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow text-center">
                    <div class="card-body">
                        <div class="fs-4 fw-bold text-danger">@lignes.Max(l => l.PrixUnitaire).ToString("N2") CHF</div>
                        <div class="text-muted">Prix maximum</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow text-center">
                    <div class="card-body">
                        <div class="fs-4 fw-bold text-warning">@lignes.Average(l => l.PrixUnitaire).ToString("N2") CHF</div>
                        <div class="text-muted">Prix moyen</div>
                    </div>
                </div>
            </div>
        </div>

        <!--Evolution globale -->
        @if (lignes.Count >= 2)
        {
            var prixDepart = lignes.First().PrixUnitaire;
            var prixActuel = lignes.Last().PrixUnitaire;
            var evolution = prixDepart != 0 ? (prixActuel - prixDepart) / prixDepart * 100m : 0m;

            <div class="card shadow mb-4">
                <div class="card-body d-flex align-items-center justify-content-between flex-wrap">
                    <div>
                        <i class="fas fa-arrow-trend-up me-2" style="color:#6C3FC5"></i>
                        <strong>Évolution globale du prix</strong>
                        <span class="text-muted">
                            (de @prixDepart.ToString("N2") CHF à @prixActuel.ToString("N2") CHF)
                        </span>
                    </div>
                    <div class="fs-4 fw-bold @(evolution > 0 ? "text-danger" : evolution < 0 ? "text-success" : "text-muted")">
                        @if (evolution > 0)
                        {
                            <i class="fas fa-arrow-up me-1"></i><text>+</text>@evolution.ToString("N1") <text>%</text>
                        }
                        else if (evolution < 0)
                        {
                            <i class="fas fa-arrow-down me-1"></i>
                            @evolution.ToString("N1")  <text>%</text>
                        }
                        else
                        {
                            <text>0.0 % (stable)</text>
                        }
                    </div>
                </div>
            </div>
        }
    }

    <!-- Historique -->
    <div class="card shadow">
        <div class="card-header">
            <i class="fas fa-history me-1"></i> Historique des prix
        </div>
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Magasin</th>
                        <th class="text-end">Quantité</th>
                        <th class="text-end">Prix unitaire CHF</th>
                        <th class="text-end">Variations</th>
                        <th class="text-end">Rabais CHF</th>
                        <th class="text-end">Total CHF</th>
                    </tr>
                </thead>
                <tbody>
                    @if (lignes == null || lignes.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-3">
                                Aucun achat enregistré pour cet article
                            </td>
                        </tr>
                    }
                    else
                    {
                        decimal? prixPrecedent = null;

                        @foreach (var ligne in lignes)
                        {
                            decimal? variation = null;
                            if (prixPrecedent.HasValue && prixPrecedent.Value != 0)
                            {
                                variation = (ligne.PrixUnitaire - prixPrecedent.Value) / prixPrecedent.Value * 100m;
                            }
                            <tr>
                                <td>
                                    <i class="fas fa-calendar-alt me-1" style="color:#A855F7"></i>
                                    @ligne.IdTicketNavigation?.DateAchat.ToString("dd.MM.yyyy")
                                </td>
                                <td>
                                    <i class="fas fa-store me-1" style="color:#A855F7"></i>
                                    @ligne.IdTicketNavigation?.Magasin?.NomMagasin
                                    <span class="text-muted">(@ligne.IdTicketNavigation?.Magasin?.Localite)</span>
                                </td>
                                <td class="text-end">@ligne.Quantite.ToString("0.###")</td>
                                <td class="text-end">@ligne.PrixUnitaire.ToString("N2")</td>
                                <td class="text-end">
                                    @if (variation == null)
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    else if (variation > 0)
                                    {
                                        <span class="text-danger fw-bold">
                                            <i class="fas fa-arrow-up"></i> +@variation.Value.ToString("N1") %
                                        </span>
                                    }
                                    else if (variation < 0)
                                    {
                                        <span class="text-success fw-bold">
                                            <i class="fas fa-arrow-down"></i> @variation.Value.ToString("N1") %
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">0.0 %</span>
                                    }
                                </td>
                                <td class="text-end">@ligne.Rabais.ToString("N2")</td>
                                <td class="text-end fw-bold">@ligne.MontantLigne.ToString("N2")</td>
                            </tr>

                            prixPrecedent = ligne.PrixUnitaire;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>
