@model List<BudgetApp.ModelsV2.Article>
@{
    ViewData["Title"] = "Articles";
    var categories = ViewBag.Categories as List<BudgetApp.ModelsV2.Categorie>;
}
<div class="container-fluid py-4">
    @if (TempData["Succes"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Succes"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erreur"] !=null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Erreur"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-box me-2"></i>Articles</h2>
        <a href="/Article/Fusionner" class="btn btn-outline-primary">
            <i class="fas fa-code-merge me-1"></i> Fusionner les doublons
        </a>
    </div>
    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Recherche</label>
                    <input type="text" name="recherche" class="form-control"
                       placeholder="Nom de l'article..." value="@ViewBag.Recherche" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Catégorie</label>
                    <select name="idCategorie" class="form-select">
                        <option value="0">Toutes les catégories</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.IdCategorie"
                                    selected="@(ViewBag.IdCategorie == cat.IdCategorie)">
                                @cat.NomCategorie
                            </option>
                        }

                    </select>

                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter me-1"></i> Filtrer
                    </button>
                </div>
                <div class="col-md-2">
                    <a href="/Article" class="btn btn-outline-secondary w-100">
                        <i class="fas fa-times me-1"></i> Réinitialiser
                    </a>
                </div>


            </form>
        </div>
    </div>
<!--Liste des articles-->
    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="thead-violet">
                    <tr>
                        <th>Article</th>
                        <th>Catégorie</th>
                        <th>Unité</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">
                                    Aucun article trouvé
                                </td>
                            </tr>
                        }
                        @foreach (var article in Model)
                        {
                            <tr>
                                <td>@article.NomArticle</td>
                                <td>@article.Categorie?.NomCategorie</td>
                                <td>@article.Unite</td>
                                <td class="text-center">
                                    <a href="/Article/Detail/@article.IdArticle"
                                        class="btn btn-info btn-sm text-white">
                                    <i class="fas fa-eye"></i> Historique
                                </a>
                                <a href="/Article/Modifier/@article.IdArticle"
                                    class="btn btn-warning btn-sm">
                                      <i class="fas fa-edit"></i> Modifier
                                </a>

                                <form method="post" action="/Article/Supprimer" class="d-inline">
                                    <input type="hidden" name="id" value="@article.IdArticle" />
                                    <button type="submit" class="btn btn-danger btn-sm"
                                        onclick="return confirm('Supprimer cet article ?')">
                                    </button>
                                </form>
                                </td>
                            </tr>
                        }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted">
            @Model.Count article(s) trouvé(s)
        </div>
    </div>
</div>
